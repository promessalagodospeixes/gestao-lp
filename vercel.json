{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "crons": [
    {
      "path": "/api/cron-fds",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/lembrete-secretario",
      "schedule": "0 11 * * 1"
    }
  ]
}
